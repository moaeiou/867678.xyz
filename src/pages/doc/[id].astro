---
//css
import { marked } from "marked";
import IndexPage from "../index.astro";
import { fetchRemoteMarkdown } from "../../lib/remote-markdown";
//md
const { content, title } = Astro.props;
export async function getStaticPaths() {
  const projects = [
    {
      id: "Mirror",
      title: "Mirrors List",
      url: "https://raw.githubusercontent.com/moaeiou/moaeiou/refs/heads/main/doc/mirror.md",
    },
    {
      id: "OpenWrt",
      title: "Anything about OpenWrt",
      url: "https://raw.githubusercontent.com/moaeiou/moaeiou/refs/heads/main/doc/openwrt.md",
    },
    {
      id: "bts",
      title: "How to build this site",
      url: "https://raw.githubusercontent.com/moaeiou/867678.xyz/refs/heads/main/README.md",
    },
    {
      id: "MoPL",
      title: "Mo Pubilc License",
      url: "https://raw.githubusercontent.com/moaeiou/moaeiou/refs/heads/main/doc/license.md",
    },
  ];
  return Promise.all(
    projects.map(async ({ id, title, url }) => ({
      params: { id },
      props: {
        title,
        content: await marked.parse(await fetchRemoteMarkdown(url)),
      },
    })),
  );
}
---

<IndexPage title={title} childpage={true}>
  <article class="markdown-body" set:html={content} />
</IndexPage>
