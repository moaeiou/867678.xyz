---
//css
import { marked } from "marked";
import IndexPage from "../index.astro";
import { fetchRemoteMarkdown } from "../../lib/remote-markdown";
//md
const { content, title } = Astro.props;
export async function getStaticPaths() {
  const projects = [
    {
      id: "qcsh",
      title: "QuickShell",
      url: "https://raw.githubusercontent.com/moaeiou/qcsh/refs/heads/main/README.md",
    },
    {
      id: "mineradio",
      title: "Mineradio",
      url: "https://raw.githubusercontent.com/moaeiou/mineradio/refs/heads/main/README.md",
    },
    {
      id: "fancyindex-theme",
      title: "Fancyindex-Theme",
      url: "https://raw.githubusercontent.com/moaeiou/fancyindex-theme/refs/heads/main/README.md",
    },
    {
      id: "contento24",
      title: "Contento24",
      url: "https://raw.githubusercontent.com/contento24/contento24/refs/heads/main/README.md",
    },
    {
      id: "luci-app-ezsgx",
      title: "LuCI-APP-EZSgX",
      url: "https://raw.githubusercontent.com/morouter/luci-app-ezsgx/main/README.md",
    },
    {
      id: "luci-app-oplist",
      title: "LuCI-APP-OPLIST",
      url: "https://raw.githubusercontent.com/morouter/luci-app-oplist/main/README.md",
    },
    {
      id: "luci-app-pm",
      title: "LuCI-APP-PM",
      url: "https://raw.githubusercontent.com/morouter/luci-app-pm/main/README.md",
    },
  ];
  return Promise.all(
    projects.map(async ({ id, title, url }) => ({
      params: { id },
      props: {
        title,
        content: await marked.parse(await fetchRemoteMarkdown(url)),
      },
    })),
  );
}
---

<IndexPage title={title} childpage={true}>
  <article class="markdown-body" set:html={content} />
</IndexPage>
