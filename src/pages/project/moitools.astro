---
//css
import "../../style/moitools.css";
//components
import IndexPage from "../index.astro";
---

<IndexPage title="MoITools" childpage={true}>
  <div class="tools-page">
    <header class="tools-header">
      <p class="eyebrow">Mo Internet Test Tools</p>
      <div class="title-row">
        <h1>MoITools</h1>
        <span class="beta-badge">Beta</span>
      </div>
      <p class="tools-summary">
        A lightweight set of browser-based diagnostics for your current
        connection and device.
      </p>
    </header>

    <section class="tools-grid" aria-label="Network diagnostics">
      <article class="tool-card ip-card">
        <div class="card-heading">
          <div>
            <p class="card-kicker">Connection</p>
            <h2>IP addresses</h2>
          </div>
          <span class="status-badge">Automatic</span>
        </div>
        <p id="sip" class="ip-result" aria-live="polite">Getting data...</p>
        <p class="card-note">Data from ipinfo and ipify.</p>
      </article>

      <article class="tool-card speed-card">
        <div class="card-heading">
          <div>
            <p class="card-kicker">Performance</p>
            <h2>Internet speed</h2>
          </div>
        </div>
        <dl class="metric-list">
          <div>
            <dt>Latency</dt>
            <dd id="latency" aria-live="polite">No data</dd>
          </div>
          <div>
            <dt>Upload</dt>
            <dd id="update-speed">Not available</dd>
          </div>
          <div>
            <dt>Download</dt>
            <dd id="download-speed" aria-live="polite">No data</dd>
          </div>
        </dl>
        <button id="sis" type="button">Run speedtest</button>
      </article>

      <article class="tool-card client-card">
        <div class="card-heading">
          <div>
            <p class="card-kicker">Browser</p>
            <h2>Client information</h2>
          </div>
        </div>
        <dl class="detail-list">
          <div><dt>User Agent</dt><dd id="user-agent">Getting data...</dd></div>
          <div>
            <dt>System Language</dt><dd id="language">Getting data...</dd>
          </div>
          <div><dt>Timezone</dt><dd id="timezone">Getting data...</dd></div>
          <div><dt>HTTP/3 support</dt><dd id="h3">Getting data...</dd></div>
        </dl>
      </article>
    </section>

    <section class="secondary-section" aria-labelledby="privacy-tests-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Privacy</p>
          <h2 id="privacy-tests-title">Leak tests</h2>
        </div>
        <span class="coming-soon">Coming soon</span>
      </div>
      <div class="leak-grid">
        <div class="leak-item">
          <h3>WebRTC leak</h3>
          <p>Check whether your browser exposes an additional IP address.</p>
        </div>
        <div class="leak-item">
          <h3>DNS leak</h3>
          <p>Inspect which DNS resolvers your connection is currently using.</p>
        </div>
      </div>
    </section>

    <aside class="privacy-note">
      <div class="privacy-icon" aria-hidden="true">✓</div>
      <div>
        <h2>Tests run in your browser</h2>
        <p>
          MoITools does not store your test results. Measurements are provided
          for reference and may vary with network conditions.
        </p>
      </div>
    </aside>
  </div>
</IndexPage>

<script>
  interface IpJson {
    ip: string;
  }
  const sipEl = document.getElementById("sip") as HTMLElement;

  const setText = (id: string, value: string): void => {
    const element = document.getElementById(id);
    if (element) element.textContent = value;
  };

  setText("user-agent", navigator.userAgent);
  setText("language", navigator.language);
  setText(
    "timezone",
    Intl.DateTimeFormat().resolvedOptions().timeZone || "Unknown",
  );
  setText("h3", "Not available");

  const fetchIps = async (): Promise<void> => {
    const fetchJson = (url: string): Promise<IpJson> =>
      fetch(url)
        .then((r) => r.json())
        .catch(() => ({ ip: "Failed" }));

    const [v4Res, v6Res, dualRes] = await Promise.all([
      fetchJson("https://ipinfo.io/json"),
      fetchJson("https://v6.ipinfo.io/json"),
      fetchJson("https://api64.ipify.org/?format=json"),
    ]);

    let preferred: string;
    if (dualRes.ip !== "Failed") {
      preferred = dualRes.ip.includes(":") ? "IPv6" : "IPv4";
    } else {
      preferred = "Unknown";
    }

    const lines = [
      `IPv4: ${v4Res.ip}`,
      `IPv6: ${v6Res.ip}`,
      `Preferred: ${preferred}`,
    ];

    sipEl.innerHTML = lines.join("<br>");
  };

  const latencyEl = document.getElementById("latency") as HTMLElement;

  const Latency = async (): Promise<void> => {
    latencyEl.textContent = "Testing latency...";
    const samples: number[] = [];
    const url = "https://www.gstatic.com/generate_204";

    for (let i = 0; i < 10; i++) {
      const start = performance.now();
      const [result] = await Promise.allSettled([
        fetch(url, { mode: "no-cors", cache: "no-store" }),
      ]);
      if (result.status === "fulfilled") {
        samples.push(performance.now() - start);
      }
      await new Promise((r) => setTimeout(r, 50));
    }

    if (samples.length) {
      samples.sort((a, b) => a - b);
      const mid = samples.slice(
        Math.floor(samples.length * 0.2),
        Math.ceil(samples.length * 0.8),
      );
      const avg = mid.reduce((a, b) => a + b, 0) / mid.length;
      latencyEl.textContent = `${avg.toFixed(1)} ms`;
    } else {
      latencyEl.textContent = "Error";
    }
  };

  const downloadEl = document.getElementById("download-speed") as HTMLElement;
  let isDownloading = false;
  const Download = async (): Promise<void> => {
    if (isDownloading) return;
    isDownloading = true;
    downloadEl.textContent = "Connecting...";

    const ctrl = new AbortController();
    const DURATION = 8000;
    const CON = 10;
    const startTime = performance.now();
    let totalBytes = 0;

    const timer = setInterval(() => {
      const sec = (performance.now() - startTime) / 1000;
      if (sec > 0.5) {
        downloadEl.textContent = `${((totalBytes * 8) / 1e6 / sec).toFixed(2)} Mbps`;
      }
    }, 150);

    const task = async (): Promise<void> => {
      const res = await fetch(
        `https://speed.cloudflare.com/__down?bytes=${1e9}`,
        {
          signal: ctrl.signal,
        },
      );
      const reader = res.body?.getReader();
      if (!reader) return;
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        totalBytes += value.length;
      }
    };

    setTimeout(() => ctrl.abort(), DURATION);

    try {
      await Promise.allSettled(Array.from({ length: CON }, task));
    } finally {
      clearInterval(timer);
      isDownloading = false;
      const finalSec = (performance.now() - startTime) / 1000;
      downloadEl.textContent =
        totalBytes > 0
          ? `${((totalBytes * 8) / 1e6 / finalSec).toFixed(2)} Mbps`
          : "Failed";
    }
  };

  let isTesting = false;
  const goBtn = document.getElementById("sis") as HTMLButtonElement;

  const Go = async (): Promise<void> => {
    if (isTesting) return;
    isTesting = true;
    goBtn.disabled = true;
    try {
      await Latency();
      await Download();
    } catch (e) {
      console.error("Something went wrong:", e);
    } finally {
      isTesting = false;
      goBtn.disabled = false;
    }
  };

  goBtn.addEventListener("click", Go);
  fetchIps();
</script>
