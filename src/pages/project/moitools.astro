---
//css
import "../../style/moitools.css";
//components
import IndexPage from "../index.astro";
---

<IndexPage title="MoITools" childpage={true}>
  <h1 style="color: white">MoITools(Beta)</h1>
  <div class="overview">
    <div class="ip">
      <h3>IPinfo</h3>
      <p id="sip">Getting data...</p>
      <p>Data from ipinfo and ipify.</p>
    </div>
    <div class="speedtest">
      <h3>Internet Speed</h3>
      <p>Latency:</p><span id="latency">No data</span>
      <p>Update:</p><span id="update-speed">No data</span>
      <p>Download:</p><span id="download-speed">No data</span>
      <button id="sis" type="button">SpeedTest</button>
    </div>
    <div class="ci">
      <h3>Client Info:</h3>
      <p>User-Agent:</p><span id="user-agent">Getting data...</span>
      <p>Language:</p><span id="language">Getting data...</span>
      <p>Timezone:</p><span id="timezone">Getting data...</span>
      <p>HTTP/3(QUIC) Support:</p><span id="h3">Getting data...</span>
    </div>
  </div>
  <div class="leak">
    <div class="webrtc-leak">
      <h3>WebRTC Leak</h3>
    </div>
    <div class="dns-leak">
      <h3>DNS Leak</h3>
    </div>
  </div>
  <div class="introducir">
    <h3>IPinfo</h3>
    <ul>
      <li>The computer using IP address to link</li>
    </ul>
    <h3>SpeedTest</h3>
    <ul>
      <li>The computer using IP address to link</li>
    </ul>
    <h3>Client Info</h3>
    <ul>
      <li>The computer using IP address to link</li>
    </ul>
    <h3>Leaks</h3>
    <ul>
      <li>The computer using IP address to link</li>
    </ul>
    <p>
      We will not collect any of your private information; please feel free to
      run the test.
    </p>
    <p>
      The test data is provided for reference only and comes with no guarantees
      of any kind.
    </p>
  </div>
</IndexPage>

<script>
  interface IpJson {
    ip: string;
  }
  const sipEl = document.getElementById("sip") as HTMLElement;
  const fetchIps = async (): Promise<void> => {
    const fetchJson = (url: string): Promise<IpJson> =>
      fetch(url)
        .then((r) => r.json())
        .catch(() => ({ ip: "Failed" }));

    const [v4Res, v6Res, dualRes] = await Promise.all([
      fetchJson("https://ipinfo.io/json"),
      fetchJson("https://v6.ipinfo.io/json"),
      fetchJson("https://api64.ipify.org/?format=json"),
    ]);

    let preferred: string;
    if (dualRes.ip !== "Failed") {
      preferred = dualRes.ip.includes(":") ? "IPv6" : "IPv4";
    } else {
      preferred = "Unknown";
    }

    const lines = [
      `IPv4: ${v4Res.ip}`,
      `IPv6: ${v6Res.ip}`,
      `Preferred: ${preferred}`,
    ];

    sipEl.innerHTML = lines.join("<br>");
  };

  const latencyEl = document.getElementById("latency") as HTMLElement;

  const Latency = async (): Promise<void> => {
    latencyEl.textContent = "Testing latency...";
    const samples: number[] = [];
    const url = "https://www.gstatic.com/generate_204";

    for (let i = 0; i < 10; i++) {
      const start = performance.now();
      try {
        await fetch(url, { mode: "no-cors", cache: "no-store" });
        samples.push(performance.now() - start);
      } catch {
        // 忽略单次失败样本
      }
      await new Promise((r) => setTimeout(r, 50));
    }

    if (samples.length) {
      samples.sort((a, b) => a - b);
      const mid = samples.slice(
        Math.floor(samples.length * 0.2),
        Math.ceil(samples.length * 0.8),
      );
      const avg = mid.reduce((a, b) => a + b, 0) / mid.length;
      latencyEl.textContent = `${avg.toFixed(1)} ms`;
    } else {
      latencyEl.textContent = "Error";
    }
  };

  const downloadEl = document.getElementById("download-speed") as HTMLElement;
  let isDownloading = false;
  const Download = async (): Promise<void> => {
    if (isDownloading) return;
    isDownloading = true;
    downloadEl.textContent = "Connecting...";

    const ctrl = new AbortController();
    const DURATION = 8000;
    const CON = 10;
    const startTime = performance.now();
    let totalBytes = 0;

    const timer = setInterval(() => {
      const sec = (performance.now() - startTime) / 1000;
      if (sec > 0.5) {
        downloadEl.textContent = `${((totalBytes * 8) / 1e6 / sec).toFixed(2)} Mbps`;
      }
    }, 150);

    const task = async (): Promise<void> => {
      try {
        const res = await fetch(
          `https://speed.cloudflare.com/__down?bytes=${1e9}`,
          {
            signal: ctrl.signal,
          },
        );
        const reader = res.body?.getReader();
        if (!reader) return;
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          totalBytes += value.length;
        }
      } catch {
        // 忽略被 abort 或网络错误
      }
    };

    setTimeout(() => ctrl.abort(), DURATION);

    try {
      await Promise.all(Array.from({ length: CON }, task));
    } finally {
      clearInterval(timer);
      isDownloading = false;
      const finalSec = (performance.now() - startTime) / 1000;
      downloadEl.textContent =
        totalBytes > 0
          ? `${((totalBytes * 8) / 1e6 / finalSec).toFixed(2)} Mbps`
          : "Failed";
    }
  };

  let isTesting = false;
  const goBtn = document.getElementById("sis") as HTMLButtonElement;

  const Go = async (): Promise<void> => {
    if (isTesting) return;
    isTesting = true;
    goBtn.disabled = true;
    try {
      await Latency();
      await Download();
    } catch (e) {
      console.error("Something went wrong:", e);
    } finally {
      isTesting = false;
      goBtn.disabled = false;
    }
  };

  goBtn.addEventListener("click", Go);
  fetchIps();
</script>
